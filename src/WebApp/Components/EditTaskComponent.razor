@using Fistix.TaskManager.ViewModel.Commands.Todos
@using Fistix.TaskManager.ViewModel.Dtos
@using FluentValidation

<MudStack Spacing="3">
  <EditForm Model="@Command" OnSubmit="HandleSubmit">
    <MudStack Spacing="3">
      <MudTextField @bind-Value="Command.Title"
                    Label="Title"
                    Variant="Variant.Outlined"
                    Error="@HasError(nameof(UpdateTodoTaskCommand.Title))"
                    ErrorText="@GetError(nameof(UpdateTodoTaskCommand.Title))" />

      <MudTextField @bind-Value="Command.Description"
                    Label="Description"
                    Variant="Variant.Outlined"
                    Lines="3"
                    Error="@HasError(nameof(UpdateTodoTaskCommand.Description))"
                    ErrorText="@GetError(nameof(UpdateTodoTaskCommand.Description))" />

      <MudDatePicker Date="_dueDate"
                     DateChanged="OnDueDateChanged"
                     Label="Due Date"
                     Variant="Variant.Outlined"
                     Error="@HasError(nameof(UpdateTodoTaskCommand.DueDate))"
                     ErrorText="@GetError(nameof(UpdateTodoTaskCommand.DueDate))" />

      <MudSelect @bind-Value="Command.Priority"
                 Label="Priority"
                 Variant="Variant.Outlined"
                 Error="@HasError(nameof(UpdateTodoTaskCommand.Priority))"
                 ErrorText="@GetError(nameof(UpdateTodoTaskCommand.Priority))">
        <MudSelectItem Value="@("High")">High</MudSelectItem>
        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
        <MudSelectItem Value="@("Low")">Low</MudSelectItem>
      </MudSelect>

      @if (!string.IsNullOrWhiteSpace(Task.AiSuggestedPriority)
           && string.Equals(Task.ClassificationStatus, "Completed", StringComparison.OrdinalIgnoreCase))
      {
        <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Variant="Variant.Outlined">
          AI suggested: <strong>@NormalizeDisplayPriority(Task.AiSuggestedPriority)</strong>
          @if (Task.AiPriorityConfidence.HasValue)
          {
            <span>(@(Math.Round(Task.AiPriorityConfidence.Value * 100))%)</span>
          }
          <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ApplySuggestedPriority" Class="ml-2">
            Use suggestion
          </MudButton>
        </MudAlert>
      }

      <MudStack Row="true" Spacing="2">
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Save</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="HandleCancel">Cancel</MudButton>
      </MudStack>
    </MudStack>
  </EditForm>
</MudStack>

@code {
    [Inject]
    private IValidator<UpdateTodoTaskCommand> Validator { get; set; } = default!;

    private UpdateTodoTaskCommand Command { get; set; } = new();
    private DateTime? _dueDate;
    private Dictionary<string, string> _errors = new();

    [Parameter]
    public TodoTaskDto Task { get; set; } = new();

    [Parameter]
    public EventCallback<UpdateTodoTaskCommand> OnSubmitForm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    protected override void OnParametersSet()
    {
        Command = new UpdateTodoTaskCommand
        {
            ExternalId = Task.ExternalId,
            Title = Task.Title ?? string.Empty,
            Description = Task.Description ?? string.Empty,
            DueDate = Task.DueDate ?? DateTime.Today.AddDays(1),
            Priority = NormalizeDisplayPriority(Task.Priority)
        };
        _dueDate = Command.DueDate;
        _errors.Clear();
    }

    private bool HasError(string field) => _errors.ContainsKey(field);

    private string GetError(string field) =>
        _errors.TryGetValue(field, out var message) ? message : string.Empty;

    private void ApplySuggestedPriority() =>
        Command.Priority = NormalizeDisplayPriority(Task.AiSuggestedPriority);

    private static string NormalizeDisplayPriority(string? priority) =>
        priority?.Trim().ToUpperInvariant() switch
        {
            "HIGH" => "High",
            "LOW" => "Low",
            "MEDIUM" => "Medium",
            _ => "Medium"
        };

    private async Task HandleSubmit()
    {
        _errors.Clear();
        if (_dueDate.HasValue)
        {
            Command.DueDate = _dueDate.Value;
        }

        var result = await Validator.ValidateAsync(Command);
        if (!result.IsValid)
        {
            foreach (var failure in result.Errors)
            {
                _errors[failure.PropertyName] = failure.ErrorMessage;
            }

            return;
        }

        await OnSubmitForm.InvokeAsync(Command);
    }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();

    private void OnDueDateChanged(DateTime? date) => _dueDate = date;
}
