@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.ViewModel.Commands.Todos
@using Fistix.TaskManager.WebApp.Services.StateServices
@using Fistix.TaskManager.WebApp.Services.DataServices
@inject TodoStateService TodoStateService
@inject TodoDataService TodoDataService

<MudStack Spacing="3" Class="mb-4">
  <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
    <MudTextField @bind-Value="_searchText"
                  Placeholder="Search tasks…"
                  Variant="Variant.Outlined"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true"
                  Style="min-width: 16rem; flex: 1;" />
    <MudSwitch @bind-Value="_useSemanticSearch" Label="Semantic search" Color="Color.Primary" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunSearch" Disabled="_searching">
      Search
    </MudButton>
  </MudStack>

  @if (!string.IsNullOrWhiteSpace(_searchError))
  {
    <MudAlert Severity="Severity.Error" Dense="true">@_searchError</MudAlert>
  }
</MudStack>

@if (_semanticResults is { Count: > 0 })
{
  <MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudText Typo="Typo.subtitle2" Class="mb-2">Semantic results (@_semanticExecutionMs ms)</MudText>
    <MudList T="SemanticSearchHitDto" Dense="true">
      @foreach (var hit in _semanticResults)
      {
        <MudListItem>
          <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Style="width:100%;">
            <div>
              <MudText Typo="Typo.body1">@hit.Title</MudText>
              <MudText Typo="Typo.caption" Color="Color.Secondary">@(hit.Description ?? "")</MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@($"{hit.Similarity:P0}")</MudChip>
          </MudStack>
        </MudListItem>
      }
    </MudList>
  </MudPaper>
}

<MudTable Items="DisplayedTasks" Hover="true" Breakpoint="Breakpoint.Sm" Loading="_searching" Dense="true">
  <HeaderContent>
    <MudTh>Title</MudTh>
    <MudTh>Due</MudTh>
    <MudTh>Status</MudTh>
    <MudTh>Priority</MudTh>
    <MudTh Style="text-align:center">Actions</MudTh>
  </HeaderContent>
  <RowTemplate>
    <MudTd DataLabel="Title">@context.Title</MudTd>
    <MudTd DataLabel="Due">@(context.DueDate?.ToString("MMM dd, yyyy") ?? "—")</MudTd>
    <MudTd DataLabel="Status">
      <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@context.Status</MudChip>
    </MudTd>
    <MudTd DataLabel="Priority">
      <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip>
    </MudTd>
    <MudTd DataLabel="Actions" Style="text-align:center">
      <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => ShowTaskDetails(context))">
        Details
      </MudButton>
    </MudTd>
  </RowTemplate>
  <NoRecordsContent>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">No tasks found</MudText>
  </NoRecordsContent>
</MudTable>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" Class="mt-3" OnClick="OnRefreshClick">Refresh</MudButton>

<MudDialog @bind-Visible="_detailsOpen" Options="_dialogOptions">
  <TitleContent>
    <MudText Typo="Typo.h6">Task Details</MudText>
  </TitleContent>
  <DialogContent>
    @if (SelectedTask is not null)
    {
      <TaskDetailsComponent TodoItem="SelectedTask"
                            OnEdit="EditTask"
                            OnClose="CloseTaskDetails"
                            OnTaskUpdated="HandleTaskUpdated" />
    }
  </DialogContent>
</MudDialog>

<MudDialog @bind-Visible="_editOpen" Options="_dialogOptions">
  <TitleContent>
    <MudText Typo="Typo.h6">Edit Task</MudText>
  </TitleContent>
  <DialogContent>
    @if (EditingTask is not null)
    {
      <EditTaskComponent Task="EditingTask"
                         OnSubmitForm="SaveEditTask"
                         OnCancel="CloseEditTask" />
    }
  </DialogContent>
</MudDialog>

@code {
  private TodoTaskDto? SelectedTask { get; set; }
  private TodoTaskDto? EditingTask { get; set; }
  private string _searchText = string.Empty;
  private bool _useSemanticSearch;
  private bool _searching;
  private bool _detailsOpen;
  private bool _editOpen;
  private string? _searchError;
  private List<SemanticSearchHitDto>? _semanticResults;
  private long _semanticExecutionMs;

  private readonly DialogOptions _dialogOptions = new()
  {
    MaxWidth = MaxWidth.Large,
    FullWidth = true,
    CloseButton = true
  };

  [Parameter]
  public List<TodoTaskDto> Tasks { get; set; } = new();

  [Parameter]
  public EventCallback OnRefresh { get; set; }

  private List<TodoTaskDto> DisplayedTasks
  {
    get
    {
      if (_useSemanticSearch && _semanticResults is { Count: > 0 })
      {
        var ids = _semanticResults.Select(r => r.TodoExternalId).ToHashSet();
        return Tasks.Where(t => ids.Contains(t.ExternalId)).ToList();
      }

      if (string.IsNullOrWhiteSpace(_searchText) || _useSemanticSearch)
      {
        return Tasks;
      }

      var term = _searchText.Trim();
      return Tasks
        .Where(t =>
          (t.Title?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
          (t.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();
    }
  }

  private async Task RunSearch()
  {
    _searchError = null;
    _semanticResults = null;

    if (!_useSemanticSearch)
    {
      return;
    }

    if (string.IsNullOrWhiteSpace(_searchText))
    {
      _searchError = "Enter a search query.";
      return;
    }

    _searching = true;
    try
    {
      var result = await TodoDataService.SemanticSearch(_searchText.Trim());
      if (!result.IsSucceed || result.Payload is null)
      {
        _searchError = result.Message ?? "Semantic search failed.";
        return;
      }

      _semanticResults = result.Payload.Results;
      _semanticExecutionMs = result.Payload.ExecutionTimeMs;
    }
    finally
    {
      _searching = false;
    }
  }

  private void OnRefreshClick()
  {
    if (OnRefresh.HasDelegate)
    {
      _ = OnRefresh.InvokeAsync();
    }
  }

  private void ShowTaskDetails(TodoTaskDto task)
  {
    SelectedTask = task;
    _detailsOpen = true;
  }

  private void CloseTaskDetails()
  {
    _detailsOpen = false;
    SelectedTask = null;
  }

  private void HandleTaskUpdated(TodoTaskDto updatedTask)
  {
    SelectedTask = updatedTask;
    TodoStateService.ReplaceTask(updatedTask);
  }

  private void EditTask()
  {
    if (SelectedTask is null)
    {
      return;
    }

    EditingTask = SelectedTask;
    _detailsOpen = false;
    _editOpen = true;
  }

  private void CloseEditTask()
  {
    _editOpen = false;
    EditingTask = null;
  }

  private void SaveEditTask(UpdateTodoTaskCommand command)
  {
    TodoStateService.UpdateTodo(command);
    CloseEditTask();
  }

  private static Color GetPriorityColor(string? priority) => priority?.ToUpperInvariant() switch
  {
    "HIGH" => Color.Error,
    "MEDIUM" => Color.Warning,
    "LOW" => Color.Success,
    _ => Color.Default
  };
}
