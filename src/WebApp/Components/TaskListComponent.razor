@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.ViewModel.Commands.Todos
@using Fistix.TaskManager.WebApp.Services.StateServices
@using Fistix.TaskManager.WebApp.Services.DataServices
@inject TodoStateService TodoStateService
@inject TodoDataService TodoDataService

<div class="mb-3">
  <div class="input-group">
    <input class="form-control" placeholder="Search tasks..." @bind="_searchText" @bind:event="oninput" />
    <div class="input-group-text">
      <input class="form-check-input mt-0 me-2" type="checkbox" id="semanticToggle" @bind="_useSemanticSearch" />
      <label class="form-check-label" for="semanticToggle">Semantic Search</label>
    </div>
    <button class="btn btn-outline-primary" @onclick="RunSearch" disabled="@_searching">Search</button>
  </div>
  @if (!string.IsNullOrWhiteSpace(_searchError))
  {
    <div class="text-danger small mt-1">@_searchError</div>
  }
</div>

@if (_semanticResults is { Count: > 0 })
{
  <div class="alert alert-light border mb-3">
    <div class="fw-semibold mb-2">Semantic results (@_semanticExecutionMs ms)</div>
    <ul class="list-unstyled mb-0">
      @foreach (var hit in _semanticResults)
      {
        <li class="mb-2 d-flex justify-content-between align-items-start gap-2">
          <div>
            <div class="fw-semibold">@hit.Title</div>
            <div class="small text-muted text-truncate" style="max-width: 40rem;">@(hit.Description ?? "")</div>
          </div>
          <span class="badge bg-primary">@($"{hit.Similarity:P0}")</span>
        </li>
      }
    </ul>
  </div>
}

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th>Id</th>
        <th>Title</th>
        <th>Due Date</th>
        <th>Status</th>
        <th>Priority</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      @if (DisplayedTasks.Count == 0)
      {
        <tr>
          <td colspan="6" class="text-center text-muted">No tasks found</td>
        </tr>
      }
      else
      {
        @foreach (var task in DisplayedTasks)
        {
          <tr>
            <td>@task.ExternalId</td>
            <td>@task.Title</td>
            <td>@(task.DueDate?.ToString("MMM dd, yyyy") ?? "-")</td>
            <td>
              <span class="badge bg-info">@task.Status</span>
            </td>
            <td>
              <span class="badge @GetPriorityBadgeClass(task.Priority)">@task.Priority</span>
            </td>
            <td class="text-center">
              <button class="btn btn-sm btn-primary" @onclick="() => ShowTaskDetails(task)" title="View details">
                Details
              </button>
            </td>
          </tr>
        }
      }
    </tbody>
  </table>
</div>

<div class="mt-3">
  <button class="btn btn-secondary" @onclick="OnRefreshClick">Refresh</button>
</div>

@if (SelectedTask != null)
{
  <div class="modal d-block" style="background-color: rgba(0,0,0,0.5);" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Task Details</h5>
          <button type="button" class="btn-close" @onclick="CloseTaskDetails" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <TaskDetailsComponent
            TodoItem="SelectedTask"
            OnEdit="EditTask"
            OnClose="CloseTaskDetails"
            OnTaskUpdated="HandleTaskUpdated">
          </TaskDetailsComponent>
        </div>
      </div>
    </div>
  </div>
}

@if (EditingTask != null)
{
  <div class="modal d-block" style="background-color: rgba(0,0,0,0.5);" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Task</h5>
          <button type="button" class="btn-close" @onclick="CloseEditTask" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <EditTaskComponent
            Task="EditingTask"
            OnSubmitForm="SaveEditTask"
            OnCancel="CloseEditTask">
          </EditTaskComponent>
        </div>
      </div>
    </div>
  </div>
}

@code {
  private TodoTaskDto? SelectedTask { get; set; }
  private TodoTaskDto? EditingTask { get; set; }
  private string _searchText = string.Empty;
  private bool _useSemanticSearch;
  private bool _searching;
  private string? _searchError;
  private List<SemanticSearchHitDto>? _semanticResults;
  private long _semanticExecutionMs;

  [Parameter]
  public List<TodoTaskDto> Tasks { get; set; } = new();

  [Parameter]
  public EventCallback OnRefresh { get; set; }

  private List<TodoTaskDto> DisplayedTasks
  {
    get
    {
      if (_useSemanticSearch && _semanticResults is { Count: > 0 })
      {
        var ids = _semanticResults.Select(r => r.TodoExternalId).ToHashSet();
        return Tasks.Where(t => ids.Contains(t.ExternalId)).ToList();
      }

      if (string.IsNullOrWhiteSpace(_searchText) || _useSemanticSearch)
      {
        return Tasks;
      }

      var term = _searchText.Trim();
      return Tasks
        .Where(t =>
          (t.Title?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
          (t.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();
    }
  }

  private async Task RunSearch()
  {
    _searchError = null;
    _semanticResults = null;

    if (!_useSemanticSearch)
    {
      return;
    }

    if (string.IsNullOrWhiteSpace(_searchText))
    {
      _searchError = "Enter a search query.";
      return;
    }

    _searching = true;
    try
    {
      var result = await TodoDataService.SemanticSearch(_searchText.Trim());
      if (!result.IsSucceed || result.Payload is null)
      {
        _searchError = result.Message ?? "Semantic search failed.";
        return;
      }

      _semanticResults = result.Payload.Results;
      _semanticExecutionMs = result.Payload.ExecutionTimeMs;
    }
    finally
    {
      _searching = false;
    }
  }

  private void OnRefreshClick()
  {
    if (OnRefresh.HasDelegate)
      OnRefresh.InvokeAsync();
  }

  private void ShowTaskDetails(TodoTaskDto task) => SelectedTask = task;
  private void CloseTaskDetails() => SelectedTask = null;

  private void HandleTaskUpdated(TodoTaskDto updatedTask)
  {
    SelectedTask = updatedTask;
    TodoStateService.ReplaceTask(updatedTask);
  }

  private void EditTask()
  {
    if (SelectedTask == null) return;
    EditingTask = SelectedTask;
    CloseTaskDetails();
  }

  private void CloseEditTask() => EditingTask = null;

  private void SaveEditTask(UpdateTodoTaskCommand command)
  {
    TodoStateService.UpdateTodo(command);
    CloseEditTask();
  }

  private string GetPriorityBadgeClass(string? priority) => priority?.ToUpperInvariant() switch
  {
    "HIGH" => "bg-danger",
    "MEDIUM" => "bg-warning text-dark",
    "LOW" => "bg-success",
    _ => "bg-secondary"
  };
}
