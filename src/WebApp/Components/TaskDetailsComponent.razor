@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.WebApp.Services.DataServices
@using Microsoft.Extensions.Logging

<div class="task-details card">
    <div class="card-header">
        <h3>@Task.Title</h3>
    </div>
    <div class="card-body">
        <!-- Task Information -->
        <div class="row mb-3">
            <div class="col-md-6">
                <p><strong>Status:</strong> <span class="badge bg-info">@Task.Status</span></p>
                <p><strong>Priority:</strong> <span class="badge bg-warning">@Task.Priority</span></p>
            </div>
            <div class="col-md-6">
                <p><strong>Due Date:</strong> @(Task.DueDate?.ToString("MMM dd, yyyy") ?? "Not set")</p>
                <p><strong>Assigned To:</strong> @(Task.AssignedTo ?? "Unassigned")</p>
            </div>
        </div>

        <!-- Description -->
        <div class="mb-3">
            <h5>Description</h5>
            <p>@Task.Description</p>
        </div>

        <!-- AI Summary Section -->
        <div class="ai-summary-section border rounded p-3 mb-3" style="background-color: #f8f9fa;">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">
                    <span class="badge bg-success">AI</span> Summary
                </h5>
                <div>
                    @if (!string.IsNullOrEmpty(Summary) && !IsLoading)
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="RegenerateSummary" title="Regenerate summary">
                            🔄 Refresh
                        </button>
                    }
                </div>
            </div>

            @if (IsLoading)
            {
                <div class="spinner-border spinner-border-sm text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="ms-2">Generating AI summary...</span>
            }
            else if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-warning mb-0">
                    <strong>⚠️ Could not generate summary:</strong> @ErrorMessage
                    <button class="btn btn-sm btn-outline-warning ms-2" @onclick="GenerateSummary">Try Again</button>
                </div>
            }
            else if (!string.IsNullOrEmpty(Summary))
            {
                <p class="mb-2">@Summary</p>
                <small class="text-muted">
                    Generated: @(SummaryGeneratedAt?.ToString("g") ?? "Unknown") |
                    Model: @(SummaryModel ?? "Unknown")@(FromCache ? " | Cached" : "")
                </small>
            }
            else
            {
                <p class="text-muted mb-0">
                    No AI summary generated yet.
                    <button class="btn btn-sm btn-link p-0" @onclick="GenerateSummary">Generate summary</button>
                </p>
            }
        </div>

        <!-- Action Buttons -->
        <div>
            <button class="btn btn-primary" @onclick="HandleEdit">Edit</button>
            <button class="btn btn-secondary" @onclick="HandleClose">Close</button>
        </div>
    </div>
</div>

@code {
    private string? Summary { get; set; }
    private string? SummaryModel { get; set; }
    private DateTime? SummaryGeneratedAt { get; set; }
    private bool FromCache { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    [Parameter]
    public TodoTaskDto Task { get; set; } = new();

    [Parameter]
    public EventCallback OnEdit { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Inject]
    public TodoDataService TodoDataService { get; set; } = default!;

    [Inject]
    public ILogger<TaskDetailsComponent> Logger { get; set; } = default!;

    protected override void OnParametersSet()
    {
        LoadSummaryFromTask();
    }

    private void LoadSummaryFromTask()
    {
        if (!string.IsNullOrWhiteSpace(Task.AiSummary))
        {
            Summary = Task.AiSummary;
            SummaryModel = Task.AiSummaryModel;
            SummaryGeneratedAt = Task.AiSummaryGeneratedAt;
            FromCache = true;
            ErrorMessage = null;
        }
    }

    private async Task HandleEdit()
    {
        await OnEdit.InvokeAsync();
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }

    private async Task GenerateSummary()
    {
        await GenerateSummaryInternal(force: false);
    }

    private async Task RegenerateSummary()
    {
        await GenerateSummaryInternal(force: true);
    }

    private async Task GenerateSummaryInternal(bool force)
    {
        if (Task == null || Task.ExternalId == Guid.Empty)
        {
            ErrorMessage = "Invalid task";
            return;
        }

        IsLoading = true;
        ErrorMessage = null;

        if (force)
        {
            Summary = null;
        }

        try
        {
            var result = await TodoDataService.Summarize(Task.ExternalId, force);

            if (result.IsSucceed && result.Payload != null)
            {
                Summary = result.Payload.Summary;
                SummaryModel = result.Payload.Model;
                SummaryGeneratedAt = result.Payload.GeneratedAt;
                FromCache = result.Payload.FromCache;
                ErrorMessage = null;

                Task.AiSummary = result.Payload.Summary;
                Task.AiSummaryModel = result.Payload.Model;
                Task.AiSummaryGeneratedAt = result.Payload.GeneratedAt;
            }
            else
            {
                Logger.LogError("Failed to generate summary: {Message}", result.Message);
                ErrorMessage = result.Message ?? "Failed to generate summary";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating summary");
            ErrorMessage = "Network error or API unavailable";
        }
        finally
        {
            IsLoading = false;
        }
    }
}

<style>
    .ai-summary-section {
        border-left: 4px solid #28a745 !important;
    }

    .task-details {
        margin: 20px 0;
    }

    .task-details .card-header {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .task-details .card-body {
        padding: 1.5rem;
    }

    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
        border-width: 0.2em;
    }
</style>
