@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.WebApp.Services
@using Fistix.TaskManager.WebApp.Services.DataServices
@using Microsoft.Extensions.Logging
@implements IAsyncDisposable

<MudStack Spacing="3">
  <MudText Typo="Typo.h5">@TodoItem.Title</MudText>

  <MudGrid>
    <MudItem xs="12" sm="6">
      <MudText Typo="Typo.body2"><strong>Status:</strong></MudText>
      <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-1">@TodoItem.Status</MudChip>
      <MudText Typo="Typo.body2" Class="mt-2"><strong>Priority:</strong></MudText>
      <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(TodoItem.Priority)" Class="ml-1">@TodoItem.Priority</MudChip>
    </MudItem>
    <MudItem xs="12" sm="6">
      <MudText Typo="Typo.body2"><strong>Due:</strong> @(TodoItem.DueDate?.ToString("MMM dd, yyyy") ?? "Not set")</MudText>
      <MudText Typo="Typo.body2" Class="mt-2"><strong>Assigned:</strong> @(TodoItem.AssignedTo ?? "Unassigned")</MudText>
    </MudItem>
  </MudGrid>

  <MudText Typo="Typo.subtitle2">Description</MudText>
  <MudText Typo="Typo.body2">@TodoItem.Description</MudText>

  <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="border-left: 4px solid var(--mud-palette-success);">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
      <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
        <MudChip T="string" Size="Size.Small" Color="Color.Success">AI</MudChip>
        <MudText Typo="Typo.subtitle1">Summary</MudText>
      </MudStack>
      @if (!string.IsNullOrEmpty(Summary) && !IsLoading)
      {
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" OnClick="RegenerateSummary" Title="Regenerate" />
      }
    </MudStack>

    @if (IsLoading)
    {
      <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        <MudText Typo="Typo.body2">Generating AI summary…</MudText>
      </MudStack>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
      <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-0">
        @ErrorMessage
        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="GenerateSummary" Class="ml-2">Try again</MudButton>
      </MudAlert>
    }
    else if (!string.IsNullOrEmpty(Summary))
    {
      <MudText Typo="Typo.body2">@Summary</MudText>
      <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
        Generated: @(SummaryGeneratedAt?.ToString("g") ?? "Unknown") · Model: @(SummaryModel ?? "Unknown")@(FromCache ? " · Cached" : "")
      </MudText>
    }
    else
    {
      <MudText Typo="Typo.body2" Color="Color.Secondary">
        No AI summary yet.
        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="GenerateSummary">Generate</MudButton>
      </MudText>
    }
  </MudPaper>

  <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="border-left: 4px solid var(--mud-palette-primary);">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
      <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
        <MudChip T="string" Size="Size.Small" Color="Color.Primary">AI</MudChip>
        <MudText Typo="Typo.subtitle1">Priority suggestion</MudText>
      </MudStack>
      @if (Classification?.Status == "Failed")
      {
        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="RetryClassification">Retry</MudButton>
      }
    </MudStack>

    @if (IsClassifying)
    {
      <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        <MudText Typo="Typo.body2">Analyzing priority…</MudText>
      </MudStack>
    }
    else if (!string.IsNullOrEmpty(ClassificationError))
    {
      <MudAlert Severity="Severity.Warning" Dense="true">@ClassificationError</MudAlert>
    }
    else if (Classification?.Status == "Completed" && !string.IsNullOrWhiteSpace(Classification.SuggestedPriority))
    {
      <MudText Typo="Typo.body2">
        Suggested:
        <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(Classification.SuggestedPriority)" Class="ml-1">
          @Classification.SuggestedPriority
        </MudChip>
        @if (Classification.Confidence.HasValue)
        {
          <span class="mud-text-secondary">(@(Math.Round(Classification.Confidence.Value * 100))% confidence)</span>
        }
      </MudText>
      @if (!string.IsNullOrWhiteSpace(Classification.Reason))
      {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">@Classification.Reason</MudText>
      }
      @if (ShouldShowApplyButton())
      {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mt-2"
                   OnClick="ApplySuggestedPriority" Disabled="IsApplyingPriority">
          Apply @Classification.SuggestedPriority
        </MudButton>
      }
      else if (Classification.Confidence is >= 0.60f and < 0.85f)
      {
        <MudText Typo="Typo.caption" Color="Color.Secondary">Recommended — review before applying.</MudText>
      }
    }
    else if (Classification?.Status == "Pending")
    {
      <MudText Typo="Typo.body2" Color="Color.Secondary">Priority analysis in progress…</MudText>
    }
    else
    {
      <MudText Typo="Typo.body2" Color="Color.Secondary">No AI priority suggestion yet.</MudText>
    }
  </MudPaper>

  <MudStack Row="true" Spacing="2">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleEdit">Edit</MudButton>
    <MudButton Variant="Variant.Outlined" OnClick="HandleClose">Close</MudButton>
  </MudStack>
</MudStack>

@code {
    private string? Summary { get; set; }
    private string? SummaryModel { get; set; }
    private DateTime? SummaryGeneratedAt { get; set; }
    private bool FromCache { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    private TaskClassificationDto? Classification { get; set; }
    private string? ClassificationError { get; set; }
    private bool IsClassifying { get; set; }
    private bool IsApplyingPriority { get; set; }
    private Guid _initializedTodoId;

    [Parameter]
    public TodoTaskDto TodoItem { get; set; } = new();

    [Parameter]
    public EventCallback OnEdit { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<TodoTaskDto> OnTaskUpdated { get; set; }

    [Inject]
    public TodoDataService TodoDataService { get; set; } = default!;

    [Inject]
    public ClassificationHubService ClassificationHubService { get; set; } = default!;

    [Inject]
    public ILogger<TaskDetailsComponent> Logger { get; set; } = default!;

    protected override async System.Threading.Tasks.Task OnParametersSetAsync()
    {
        LoadSummaryFromTodoItem();

        if (TodoItem.ExternalId == Guid.Empty || TodoItem.ExternalId == _initializedTodoId)
        {
            return;
        }

        _initializedTodoId = TodoItem.ExternalId;
        LoadClassificationFromTodoItem();
        ClassificationHubService.ClassificationUpdated -= OnClassificationPushed;
        ClassificationHubService.ClassificationUpdated += OnClassificationPushed;
        await ClassificationHubService.SubscribeToTodoAsync(TodoItem.ExternalId);
        await LoadClassificationStatusAsync();
    }

    public async ValueTask DisposeAsync()
    {
        ClassificationHubService.ClassificationUpdated -= OnClassificationPushed;

        if (_initializedTodoId != Guid.Empty)
        {
            await ClassificationHubService.LeaveTodoAsync(_initializedTodoId);
        }
    }

    private void OnClassificationPushed(TaskClassificationDto dto)
    {
        if (dto.TodoExternalId != TodoItem.ExternalId)
        {
            return;
        }

        Classification = dto;
        SyncClassificationToTodoItem();
        IsClassifying = dto.Status == "Pending";
        _ = InvokeAsync(StateHasChanged);
    }

    private void LoadSummaryFromTodoItem()
    {
        if (!string.IsNullOrWhiteSpace(TodoItem.AiSummary))
        {
            Summary = TodoItem.AiSummary;
            SummaryModel = TodoItem.AiSummaryModel;
            SummaryGeneratedAt = TodoItem.AiSummaryGeneratedAt;
            FromCache = true;
            ErrorMessage = null;
        }
    }

    private void LoadClassificationFromTodoItem()
    {
        if (!string.IsNullOrWhiteSpace(TodoItem.ClassificationStatus))
        {
            Classification = new TaskClassificationDto
            {
                TodoExternalId = TodoItem.ExternalId,
                SuggestedPriority = TodoItem.AiSuggestedPriority,
                Confidence = TodoItem.AiPriorityConfidence,
                Reason = TodoItem.AiPriorityReason,
                Status = TodoItem.ClassificationStatus,
                Model = TodoItem.AiPriorityModel,
                FromCache = true,
                GeneratedAt = TodoItem.AiPriorityGeneratedAt
            };
        }
    }

    private async System.Threading.Tasks.Task LoadClassificationStatusAsync()
    {
        if (TodoItem.ExternalId == Guid.Empty)
        {
            return;
        }

        IsClassifying = Classification?.Status == "Pending" || Classification is null;
        ClassificationError = null;

        try
        {
            var result = await TodoDataService.GetClassification(TodoItem.ExternalId);
            if (result.IsSucceed && result.Payload is not null)
            {
                Classification = result.Payload;
                SyncClassificationToTodoItem();
            }
            else
            {
                ClassificationError = result.Message ?? "Failed to load classification status";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading classification status");
            ClassificationError = "Network error or API unavailable";
        }
        finally
        {
            IsClassifying = Classification?.Status == "Pending";
        }
    }

    private async System.Threading.Tasks.Task RetryClassification()
    {
        IsClassifying = true;
        ClassificationError = null;

        try
        {
            var result = await TodoDataService.Classify(TodoItem.ExternalId, force: true);
            if (result.IsSucceed && result.Payload is not null)
            {
                Classification = result.Payload;
                SyncClassificationToTodoItem();
            }
            else
            {
                ClassificationError = result.Message ?? "Failed to retry classification";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error retrying classification");
            ClassificationError = "Network error or API unavailable";
        }
        finally
        {
            IsClassifying = Classification?.Status == "Pending";
        }
    }

    private bool ShouldShowApplyButton()
    {
        if (Classification?.Status != "Completed" || string.IsNullOrWhiteSpace(Classification.SuggestedPriority))
        {
            return false;
        }

        if (Classification.Confidence is < 0.60f)
        {
            return false;
        }

        return !string.Equals(
            NormalizePriority(TodoItem.Priority),
            Classification.SuggestedPriority,
            StringComparison.OrdinalIgnoreCase);
    }

    private async System.Threading.Tasks.Task ApplySuggestedPriority()
    {
        IsApplyingPriority = true;
        try
        {
            var result = await TodoDataService.ApplyAiPriority(TodoItem.ExternalId);
            if (result.IsSucceed && result.Payload is not null)
            {
                TodoItem.Priority = result.Payload.Priority;
                await OnTaskUpdated.InvokeAsync(result.Payload);
            }
            else
            {
                ClassificationError = result.Message ?? "Failed to apply AI priority";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error applying AI priority");
            ClassificationError = "Network error or API unavailable";
        }
        finally
        {
            IsApplyingPriority = false;
        }
    }

    private void SyncClassificationToTodoItem()
    {
        if (Classification is null)
        {
            return;
        }

        TodoItem.AiSuggestedPriority = Classification.SuggestedPriority;
        TodoItem.AiPriorityConfidence = Classification.Confidence;
        TodoItem.AiPriorityReason = Classification.Reason;
        TodoItem.ClassificationStatus = Classification.Status;
        TodoItem.AiPriorityModel = Classification.Model;
        TodoItem.AiPriorityGeneratedAt = Classification.GeneratedAt;
    }

    private static string NormalizePriority(string? priority) =>
        priority?.Trim().ToUpperInvariant() switch
        {
            "HIGH" => "HIGH",
            "LOW" => "LOW",
            "MEDIUM" => "MEDIUM",
            _ => priority?.ToUpperInvariant() ?? string.Empty
        };

    private static Color GetPriorityColor(string? priority) => priority?.ToUpperInvariant() switch
    {
        "HIGH" => Color.Error,
        "MEDIUM" => Color.Warning,
        "LOW" => Color.Success,
        _ => Color.Default
    };

    private async System.Threading.Tasks.Task HandleEdit() => await OnEdit.InvokeAsync();

    private async System.Threading.Tasks.Task HandleClose() => await OnClose.InvokeAsync();

    private async System.Threading.Tasks.Task GenerateSummary() => await GenerateSummaryInternal(force: false);

    private async System.Threading.Tasks.Task RegenerateSummary() => await GenerateSummaryInternal(force: true);

    private async System.Threading.Tasks.Task GenerateSummaryInternal(bool force)
    {
        if (TodoItem.ExternalId == Guid.Empty)
        {
            ErrorMessage = "Invalid task";
            return;
        }

        IsLoading = true;
        ErrorMessage = null;

        if (force)
        {
            Summary = null;
        }

        try
        {
            var result = await TodoDataService.Summarize(TodoItem.ExternalId, force);

            if (result.IsSucceed && result.Payload != null)
            {
                Summary = result.Payload.Summary;
                SummaryModel = result.Payload.Model;
                SummaryGeneratedAt = result.Payload.GeneratedAt;
                FromCache = result.Payload.FromCache;
                ErrorMessage = null;

                TodoItem.AiSummary = result.Payload.Summary;
                TodoItem.AiSummaryModel = result.Payload.Model;
                TodoItem.AiSummaryGeneratedAt = result.Payload.GeneratedAt;
            }
            else
            {
                Logger.LogError("Failed to generate summary: {Message}", result.Message);
                ErrorMessage = result.Message ?? "Failed to generate summary";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating summary");
            ErrorMessage = "Network error or API unavailable";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
