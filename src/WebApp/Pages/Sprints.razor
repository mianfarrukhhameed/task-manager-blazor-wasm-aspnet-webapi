@page "/sprints"
@attribute [Authorize]

@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.WebApp.Services.DataServices

@inject TodoDataService TodoDataService

<MudText Typo="Typo.h4" GutterBottom="true">Sprints</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
  Sprints created by the AI sprint optimizer.
</MudText>

@if (!string.IsNullOrWhiteSpace(_error))
{
  <MudAlert Severity="Severity.Warning" Class="mb-4">@_error</MudAlert>
}

<MudStack Row="true" Spacing="2" Class="mb-4">
  <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading" OnClick="LoadAsync">
    Refresh
  </MudButton>
  <MudButton Href="ai-chat" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoAwesome">
    Optimize a sprint
  </MudButton>
</MudStack>

@if (_loading && _sprints.Count == 0)
{
  <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_sprints.Count == 0)
{
  <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
    No sprints yet. Use AI Chat → Optimize Sprint to create one.
  </MudAlert>
}
else
{
  <MudTable Items="_sprints" Hover="true" Breakpoint="Breakpoint.Sm" Loading="_loading" OnRowClick="OnRowClick" T="SprintDto">
    <HeaderContent>
      <MudTh>Name</MudTh>
      <MudTh>Dates</MudTh>
      <MudTh>Tasks</MudTh>
      <MudTh>Created</MudTh>
      <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
      <MudTd DataLabel="Name">@context.Name</MudTd>
      <MudTd DataLabel="Dates">
        <MudText Typo="Typo.caption">@context.StartDate.ToString("yyyy-MM-dd") – @context.EndDate.ToString("yyyy-MM-dd")</MudText>
      </MudTd>
      <MudTd DataLabel="Tasks">@context.Tasks.Count</MudTd>
      <MudTd DataLabel="Created">
        <MudText Typo="Typo.caption">@context.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</MudText>
      </MudTd>
      <MudTd>
        <MudButton Href="@($"sprints/{context.ExternalId}")" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
          View
        </MudButton>
      </MudTd>
    </RowTemplate>
  </MudTable>
}

@code {
  private readonly List<SprintDto> _sprints = new();
  private string? _error;
  private bool _loading;

  [Inject]
  private NavigationManager Navigation { get; set; } = default!;

  protected override async Task OnInitializedAsync() => await LoadAsync();

  private async Task LoadAsync()
  {
    _loading = true;
    _error = null;
    try
    {
      var result = await TodoDataService.GetSprints();
      _sprints.Clear();
      if (result.IsSucceed && result.Payload is not null)
      {
        _sprints.AddRange(result.Payload);
      }
      else
      {
        _error = result.Message ?? "Failed to load sprints.";
      }
    }
    finally
    {
      _loading = false;
    }
  }

  private void OnRowClick(TableRowClickEventArgs<SprintDto> args)
  {
    if (args.Item is not null)
    {
      Navigation.NavigateTo($"sprints/{args.Item.ExternalId}");
    }
  }
}
