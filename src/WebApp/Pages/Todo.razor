@page "/todo"
@implements IDisposable
@attribute [Authorize]

@using Fistix.TaskManager.WebApp.Components
@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.ViewModel.Commands.Todos
@using Fistix.TaskManager.ViewModel.Queries.Todos
@using Fistix.TaskManager.WebApp.Services.StateServices

@inject TodoStateService _TodoStateService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" GutterBottom="true">Todo Tasks</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
  Manage tasks, semantic search, and AI summaries.
</MudText>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
  <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
}

<MudGrid>
  <MudItem xs="12" lg="8">
    <TaskListComponent Tasks="@_tasks" OnRefresh="GetAllTodos" />
  </MudItem>
  <MudItem xs="12" lg="4">
    <CreateTaskComponent OnSubmitForm="@(e => OnCreateTask((CreateTodoTaskCommand)e))" />
  </MudItem>
</MudGrid>

@code {
  private string _errorMessage = string.Empty;
  private List<TodoTaskDto> _tasks = new();
  private List<IDisposable> _subscriptions = new();

  protected override void OnInitialized()
  {
    RegisterSubscriptions();
  }

  private void RegisterSubscriptions()
  {
    _subscriptions.Add(
     _TodoStateService.TodoTasksObservable.Subscribe(x =>
     {
       _tasks = x;
       StateHasChanged();
     })
   );

    _subscriptions.Add(
      _TodoStateService.ApiCallResultObservable.Subscribe(x =>
      {
        switch (x.Operation)
        {
          case nameof(GetAllTodoTasksQuery):
            if (!x.IsSucceed)
            {
              _errorMessage = x.Message;
              Snackbar.Add(x.Message ?? "Failed to load todos", Severity.Error);
              StateHasChanged();
            }
            break;

          case nameof(CreateTodoTaskCommand):
            if (x.IsSucceed)
            {
              Snackbar.Add("Task created", Severity.Success);
            }
            else
            {
              _errorMessage = x.Message;
              Snackbar.Add(x.Message ?? "Failed to create task", Severity.Error);
              StateHasChanged();
            }
            break;

          case nameof(UpdateTodoTaskCommand):
            if (x.IsSucceed)
            {
              Snackbar.Add("Task updated", Severity.Success);
            }
            else
            {
              _errorMessage = x.Message;
              Snackbar.Add(x.Message ?? "Failed to update task", Severity.Error);
              StateHasChanged();
            }
            break;
        }
      })
    );
  }

  private void GetAllTodos()
  {
    _errorMessage = string.Empty;
    _TodoStateService.GetAllTodos();
  }

  private void OnCreateTask(CreateTodoTaskCommand command)
  {
    _errorMessage = string.Empty;
    _TodoStateService.CreateTodo(command);
  }

  public void Dispose()
  {
    foreach (var subscription in _subscriptions)
    {
      subscription.Dispose();
    }
  }
}
