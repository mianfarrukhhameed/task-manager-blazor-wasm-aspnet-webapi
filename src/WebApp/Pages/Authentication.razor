@page "/authentication/{action}"

@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

<MudContainer Class="d-flex justify-center align-center" Style="min-height: 60vh;">
  <MudPaper Class="pa-6" Elevation="2" Style="min-width: 20rem; text-align: center;">
    @if (IsLogoutAction)
    {
      <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mb-3" />
      <MudText Typo="Typo.body1">Signing you out…</MudText>
    }
    else
    {
      <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mb-3" />
      <MudText Typo="Typo.body1">Completing sign-in…</MudText>
      <RemoteAuthenticatorView Action="@Action" />
    }
  </MudPaper>
</MudContainer>
