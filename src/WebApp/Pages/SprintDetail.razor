@page "/sprints/{ExternalId:guid}"
@attribute [Authorize]

@using Fistix.TaskManager.ViewModel.Dtos
@using Fistix.TaskManager.WebApp.Services.DataServices

@inject TodoDataService TodoDataService

<MudButton Href="sprints" StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Class="mb-4">
  All sprints
</MudButton>

@if (!string.IsNullOrWhiteSpace(_error))
{
  <MudAlert Severity="Severity.Warning">@_error</MudAlert>
}
else if (_loading || _sprint is null)
{
  <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
  <MudText Typo="Typo.h4" GutterBottom="true">@_sprint.Name</MudText>
  <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @_sprint.StartDate.ToString("yyyy-MM-dd") – @_sprint.EndDate.ToString("yyyy-MM-dd")
    · created @_sprint.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC
    · <code>@_sprint.ExternalId</code>
  </MudText>

  @if (!string.IsNullOrWhiteSpace(_sprint.Reasoning))
  {
    <MudPaper Class="pa-4 mb-4" Elevation="1">
      <MudText Typo="Typo.subtitle1" Class="mb-2">Optimizer reasoning</MudText>
      <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_sprint.Reasoning</MudText>
    </MudPaper>
  }

  <MudText Typo="Typo.h6" Class="mb-2">Selected tasks (@_sprint.Tasks.Count)</MudText>

  @if (_sprint.Tasks.Count == 0)
  {
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No tasks linked to this sprint.</MudAlert>
  }
  else
  {
    <MudTable Items="_sprint.Tasks" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
      <HeaderContent>
        <MudTh>Title</MudTh>
        <MudTh>Priority</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Due</MudTh>
      </HeaderContent>
      <RowTemplate>
        <MudTd DataLabel="Title">@context.Title</MudTd>
        <MudTd DataLabel="Priority">
          <MudChip T="string" Size="Size.Small">@context.Priority</MudChip>
        </MudTd>
        <MudTd DataLabel="Status">@context.Status</MudTd>
        <MudTd DataLabel="Due">@(context.DueDate?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
      </RowTemplate>
    </MudTable>
  }
}

@code {
  [Parameter] public Guid ExternalId { get; set; }

  private SprintDto? _sprint;
  private string? _error;
  private bool _loading = true;

  protected override async Task OnParametersSetAsync()
  {
    _loading = true;
    _error = null;
    _sprint = null;
    try
    {
      var result = await TodoDataService.GetSprint(ExternalId);
      if (result.IsSucceed && result.Payload is not null)
      {
        _sprint = result.Payload;
      }
      else
      {
        _error = result.Message ?? "Sprint not found.";
      }
    }
    finally
    {
      _loading = false;
    }
  }
}
