@page "/ai-chat"
@attribute [Authorize]
@using System.Text.Json
@using Fistix.TaskManager.ViewModel.Commands.Todos
@using Fistix.TaskManager.WebApp.Services.DataServices
@inject TodoDataService TodoDataService

<MudText Typo="Typo.h4" GutterBottom="true">AI Task Assistant</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
  Ask questions about your workload, propose tool actions, or optimize a sprint.
</MudText>

<MudTabs @bind-ActivePanelIndex="_tabIndex" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
  <MudTabPanel Text="Ask (RAG)" Icon="@Icons.Material.Filled.QuestionAnswer">
    <MudStack Spacing="3" Style="max-width: 40rem;">
      <MudSelect @bind-Value="_context" Label="Context" Variant="Variant.Outlined">
        <MudSelectItem Value="@("workload")">workload</MudSelectItem>
        <MudSelectItem Value="@("week")">week</MudSelectItem>
        <MudSelectItem Value="@("project")">project</MudSelectItem>
      </MudSelect>
      <MudTextField @bind-Value="_question"
                    Label="Question"
                    Variant="Variant.Outlined"
                    Lines="3"
                    Placeholder="What am I working on this week?" />
      <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_loading" OnClick="AskAsync">Ask</MudButton>
    </MudStack>
  </MudTabPanel>

  <MudTabPanel Text="Function calling" Icon="@Icons.Material.Filled.Build">
    <MudStack Spacing="3" Style="max-width: 40rem;">
      <MudTextField @bind-Value="_toolPrompt"
                    Label="Prompt"
                    Variant="Variant.Outlined"
                    Lines="3"
                    Placeholder="Create 3 tasks for Q2 planning with high priority" />
      <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_loading" OnClick="ProposeToolsAsync">
        Propose tools
      </MudButton>

      @if (_proposal is not null)
      {
        <MudPaper Class="pa-4" Elevation="1">
          <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Model: @_proposal.Model</MudText>
          <MudText Typo="Typo.body2" Class="mb-3">@_proposal.Explanation</MudText>

          @if (_proposal.ProposedCalls.Count == 0)
          {
            <MudText Color="Color.Secondary">No tool calls proposed.</MudText>
          }
          else
          {
            <MudText Typo="Typo.subtitle2" Class="mb-2">Proposed calls</MudText>
            @foreach (var call in _proposal.ProposedCalls)
            {
              <MudPaper Class="pa-3 mb-2" Outlined="true">
                <MudText Typo="Typo.body2"><code>@call.ToolName</code></MudText>
                <MudText Typo="Typo.caption" Style="white-space: pre-wrap; font-family: monospace;">@FormatArgs(call.Arguments)</MudText>
              </MudPaper>
            }
            <MudStack Row="true" Spacing="2" Class="mt-3">
              <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="_loading" OnClick="ExecuteToolsAsync">
                Confirm &amp; execute
              </MudButton>
              <MudButton Variant="Variant.Outlined" Disabled="_loading" OnClick="ClearProposal">Cancel</MudButton>
            </MudStack>
          }
        </MudPaper>
      }

      @if (_execution is not null)
      {
        <MudPaper Class="pa-4" Elevation="1">
          <MudText Typo="Typo.subtitle2" Class="mb-2">Execution results</MudText>
          @foreach (var result in _execution.Results)
          {
            <MudPaper Class="pa-3 mb-2" Outlined="true">
              <MudChip T="string" Size="Size.Small" Color="@(result.Success ? Color.Success : Color.Error)">
                @(result.Success ? "ok" : "failed")
              </MudChip>
              <code class="ml-2">@result.ToolName</code>
              <MudText Typo="Typo.body2" Class="mt-1">@result.Message</MudText>
              @if (!string.IsNullOrWhiteSpace(result.ResultJson))
              {
                <MudText Typo="Typo.caption" Style="white-space: pre-wrap; font-family: monospace;">@result.ResultJson</MudText>
              }
            </MudPaper>
          }
        </MudPaper>
      }
    </MudStack>
  </MudTabPanel>

  <MudTabPanel Text="Optimize Sprint" Icon="@Icons.Material.Filled.AutoAwesome">
    <MudGrid Spacing="3" Class="mb-4" Style="max-width: 40rem;">
      <MudItem xs="12" sm="4">
        <MudNumericField @bind-Value="_maxTasks" Label="Max tasks" Min="1" Max="50" Variant="Variant.Outlined" />
      </MudItem>
      <MudItem xs="12" sm="4">
        <MudNumericField @bind-Value="_durationDays" Label="Duration (days)" Min="1" Max="90" Variant="Variant.Outlined" />
      </MudItem>
      <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_sprintName" Label="Name (optional)" Variant="Variant.Outlined" Placeholder="Sprint name" />
      </MudItem>
    </MudGrid>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_loading" OnClick="OptimizeSprintAsync">
      Optimize Sprint
    </MudButton>

    @if (_sprintResult is not null)
    {
      <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6">@_sprintResult.Name</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
          Sprint id: <code>@_sprintResult.SprintId</code>
          · @_sprintResult.StartDate.ToString("yyyy-MM-dd") – @_sprintResult.EndDate.ToString("yyyy-MM-dd")
        </MudText>

        <MudButton Href="@($"sprints/{_sprintResult.SprintId}")"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.OpenInNew"
                   Class="mb-4">
          Open sprint details
        </MudButton>

        @if (_sprintResult.Steps.Count > 0)
        {
          <MudText Typo="Typo.subtitle2" Class="mb-2">Agent steps (Analyst → Planner)</MudText>
          <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var step in _sprintResult.Steps)
            {
              <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                <MudText Typo="Typo.body2">
                  <strong>@step.AgentName</strong> / <code>@step.ToolName</code>
                </MudText>
                @if (!string.IsNullOrWhiteSpace(step.Summary))
                {
                  <MudText Typo="Typo.caption" Color="Color.Secondary">@step.Summary</MudText>
                }
              </MudTimelineItem>
            }
          </MudTimeline>
        }

        <MudText Typo="Typo.body2" Style="white-space: pre-wrap;" Class="mb-4">@_sprintResult.Reasoning</MudText>

        @if (_sprintResult.SelectedTasks.Count == 0)
        {
          <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No tasks were selected.</MudAlert>
        }
        else
        {
          <MudText Typo="Typo.subtitle2" Class="mb-2">Selected tasks (@_sprintResult.SelectedTasks.Count)</MudText>
          <MudList T="string" Dense="true">
            @foreach (var task in _sprintResult.SelectedTasks)
            {
              <MudListItem>
                <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width:100%;">
                  <div>
                    <MudText Typo="Typo.body2">@task.Title</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                      @task.Priority · @task.Status
                      @if (task.DueDate is not null)
                      {
                        <span>· due @task.DueDate.Value.ToString("yyyy-MM-dd")</span>
                      }
                    </MudText>
                  </div>
                  <MudText Typo="Typo.caption"><code>@task.ExternalId</code></MudText>
                </MudStack>
              </MudListItem>
            }
          </MudList>
        }
      </MudPaper>
    }
  </MudTabPanel>
</MudTabs>

@if (_loading)
{
  <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
}

@if (!string.IsNullOrWhiteSpace(_error))
{
  <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
}

@if (_response is not null)
{
  <MudPaper Class="pa-4 mt-4" Elevation="2">
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
      Model: @_response.Model · Context: @_response.Context
    </MudText>
    <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">@_response.Answer</MudText>
    @if (_response.Sources.Count > 0)
    {
      <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Sources</MudText>
      <MudList T="string" Dense="true">
        @foreach (var source in _response.Sources)
        {
          <MudListItem><code>@source</code></MudListItem>
        }
      </MudList>
    }
  </MudPaper>
}

@code {
  private int _tabIndex;
  private string _question = string.Empty;
  private string _context = "workload";
  private string _toolPrompt = string.Empty;
  private int _maxTasks = 12;
  private int _durationDays = 14;
  private string _sprintName = string.Empty;
  private bool _loading;
  private string? _error;
  private AiQueryResponseDto? _response;
  private ProposeAiToolsResponseDto? _proposal;
  private ExecuteAiToolsResponseDto? _execution;
  private OptimizeSprintResponseDto? _sprintResult;

  private async Task AskAsync()
  {
    _error = null;
    _response = null;
    _proposal = null;
    _execution = null;
    _sprintResult = null;
    if (string.IsNullOrWhiteSpace(_question))
    {
      _error = "Enter a question.";
      return;
    }

    _loading = true;
    try
    {
      var result = await TodoDataService.AiQuery(_question.Trim(), _context);
      if (!result.IsSucceed || result.Payload is null)
      {
        _error = result.Message ?? "AI query failed.";
        return;
      }

      _response = result.Payload;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task ProposeToolsAsync()
  {
    _error = null;
    _response = null;
    _proposal = null;
    _execution = null;
    _sprintResult = null;
    if (string.IsNullOrWhiteSpace(_toolPrompt))
    {
      _error = "Enter a prompt.";
      return;
    }

    _loading = true;
    try
    {
      var result = await TodoDataService.ProposeAiTools(_toolPrompt.Trim());
      if (!result.IsSucceed || result.Payload is null)
      {
        _error = result.Message ?? "Tool proposal failed.";
        return;
      }

      _proposal = result.Payload;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task ExecuteToolsAsync()
  {
    if (_proposal is null || _proposal.ProposedCalls.Count == 0)
    {
      return;
    }

    _error = null;
    _execution = null;
    _loading = true;
    try
    {
      var result = await TodoDataService.ExecuteAiTools(_proposal.ProposedCalls);
      if (!result.IsSucceed || result.Payload is null)
      {
        _error = result.Message ?? "Tool execution failed.";
        return;
      }

      _execution = result.Payload;
    }
    finally
    {
      _loading = false;
    }
  }

  private async Task OptimizeSprintAsync()
  {
    _error = null;
    _response = null;
    _proposal = null;
    _execution = null;
    _sprintResult = null;
    _loading = true;
    try
    {
      var result = await TodoDataService.OptimizeSprint(
        _maxTasks,
        _durationDays,
        string.IsNullOrWhiteSpace(_sprintName) ? null : _sprintName.Trim());
      if (!result.IsSucceed || result.Payload is null)
      {
        _error = result.Message ?? "Sprint optimization failed.";
        return;
      }

      _sprintResult = result.Payload;
    }
    finally
    {
      _loading = false;
    }
  }

  private void ClearProposal()
  {
    _proposal = null;
    _execution = null;
  }

  private static string FormatArgs(Dictionary<string, JsonElement> args) =>
    JsonSerializer.Serialize(args, new JsonSerializerOptions { WriteIndented = true });
}
