    },
    "Embedding": {
      "Provider": "Onnx",
      "Model": "bge-small-en-v1.5",
      "Dimension": 384,
      "ApiKey": "",
      "Endpoint": "https://api.openai.com/v1",
      "Onnx": {
        "ModelDirectory": "models/bge-small-en-v1.5",
        "MaxSequenceLength": 512,
        "QueryInstruction": "Represent this sentence for searching: "
      }
    },
    "Features": {
      "EnableSummarization": true,
      "SummarizeRateLimit": {
        "Enabled": true,
        "PermitLimit": 1,
        "WindowMinutes": 1
      },
      "EnableClassification": true,
      "ClassifyRateLimit": {
        "Enabled": true,
        "PermitLimit": 5,
        "WindowMinutes": 1
      },
      "Classification": {
        "RequestTimeoutMs": 15000,
        "MaxRetries": 1,
        "RetryDelayMs": 500,
        "MaxDegreeOfParallelism": 3
      },
      "EnableEmbeddings": true,
      "EnableSemanticSearch": true,
      "SemanticSearch": {
        "MinSimilarity": 0.45
      },
      "SemanticSearchRateLimit": {
        "Enabled": true,
        "PermitLimit": 10,
        "WindowMinutes": 1
      },
      "EnableRag": true,
      "RagRateLimit": {
        "Enabled": true,
        "PermitLimit": 5,
        "WindowMinutes": 1
      },
      "EnableFunctionCalling": false,
      "FunctionCallingRateLimit": {
        "Enabled": true,
        "PermitLimit": 5,
        "WindowMinutes": 1
      },
      "EnableAgents": true,
      "AgentsRateLimit": {
        "Enabled": true,
        "PermitLimit": 3,
        "WindowMinutes": 1
      },
      "EnableMcp": true
    }
  }
